    <!-- About -->
    <string name="about">About</string>
    <string name="about_title">About IManage</string>
    <string name="about_description">IManage is your all-in-one personal financial and task management app. Track expenses, incomes, debts, receivables, bank cards, trips, car services, passwords and much more — all in one place.</string>
